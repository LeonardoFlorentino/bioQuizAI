# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ==============================================================================
# BACKEND (Java / Maven)
# ==============================================================================
**/target/
**/*.class
.mvn/wrapper/maven-wrapper.jar

# ==============================================================================
# FRONTEND (Angular / Node)
# ==============================================================================
# Ao remover a '/' do início, o Git ignora essas pastas em qualquer nível do projeto
.angular/
dist/
tmp/
out-tsc/
bazel-out/
node_modules/
.angular/cache/
.sass-cache/
connect.lock/
coverage/
__screenshots__/
typings/

# Logs do Node (valem para qualquer pasta)
npm-debug.log
yarn-error.log
/libpeerconnection.log
testem.log

# ==============================================================================
# FERRAMENTAS & IDEs (Globais para o projeto)
# ==============================================================================
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# System files
.DS_Store
Thumbs.db